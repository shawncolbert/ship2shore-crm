# ── Client (Vite) — safe to expose, prefixed VITE_ ──────────────────
# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ── Server (Netlify Functions) — SECRET. Set these in Netlify →
#    Site settings → Environment. For local `netlify dev`, keep them here.
#    Never prefix these with VITE_ and never commit real values. ────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
ORG_ID=11111111-1111-1111-1111-111111111111

# The Gmail address the inbox sends from and syncs
GMAIL_ADDRESS=you@yourdomain.com

# Google OAuth (see README → "Connecting Gmail")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
